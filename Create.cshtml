@model ProductDto
@{
}
<div class="row">
    <div class="col-md-8 mx-auto rounded border p-3">
        <h2 class="text-center mb-5">New Book</h2>
        <form method="post" enctype="multipart/form-data">

            <div class="row mb-3">

                <label class="col-sm-4  col-form-label">Name</label>

                <div class="col-sm-8">
                    <input class="form-control" asp-for="Name" />
                    <span asp-validation-for="Name" class="text-danger"></span>
                </div>

            </div>

            <div class="row mb-3">

                <label class="col-sm-4  col-form-label">Author Name</label>

                <div class="col-sm-8">
                    <input class="form-control" asp-for="Brand" />
                    <span asp-validation-for="Brand" class="text-danger"></span>
                </div>

            </div>

            <div class="row mb-3">

                <label class="col-sm-4  col-form-label">Category</label>

                <div class="col-sm-8">
                    <select class="form-select" asp-for="Category">

                        <option value="Others">Others</option>
                        <option value="Sci-fic">Sci-fic</option>
                        <option value="Thriller">Thriller</option>
                        <option value="Knowldege">Knowledge</option>
                        <option value="Love">Love</option>
                        <option value="Story">Story</option>\
                        <option value="Fiction">Fiction</option>
                        <option value="Motivational">Motivational</option>
                    </select>

                </div>

            </div>
            <div class="row mb-3">

                <div class="row mb-3">
                    <label class="col-sm-4 col-form-label">Quantity</label>
                    <div class="col-sm-8">
                        <input type="number" class="form-control" asp-for="Quantity">
                        <span asp-validation-for="Quantity" class="text-danger"></span>
                    </div>


                </div>
            </div>

            <div class="row mb-3">

                <label class="col-sm-4  col-form-label">Description</label>

                <div class="col-sm-8">
                    <input class="form-control" asp-for="Description" />
                    <span asp-validation-for="Description" class="text-danger"></span>
                </div>

            </div>

            <div class="row mb-3">

                <label class="col-sm-4  col-form-label">Image</label>

                <div class="col-sm-8">
                    <input class="form-control" asp-for="ImageFile" />
                    <span asp-validation-for="ImageFile" class="text-danger"></span>
                </div>

            </div>

            <div class="row">
                <div class="offset-sm-4 col-sm-4 d-grid">
                    <button type="submit" class="btn btn-primary">Submit</button>
                </div>
                <div class="col-sm-4 d-grid">
                    <a class="btn btn-outline-primary" asp-controller="Product" asp-action="Index" role="button">
                        Cancel
                    </a>
                </div>
            </div>


        </form>

    </div>
</div>
